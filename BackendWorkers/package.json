{
  "name": "world-cup-predictor-workers",
  "version": "1.0.0",
  "description": "Cloudflare Workers backend (Hono + D1) for World Cup Predictor",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute worldcup --local --file=./migrations/0001_schema.sql",
    "db:seed:local": "wrangler d1 execute worldcup --local --file=./migrations/0002_seed.sql",
    "db:migrate:remote": "wrangler d1 execute worldcup --remote --file=./migrations/0001_schema.sql",
    "db:seed:remote": "wrangler d1 execute worldcup --remote --file=./migrations/0002_seed.sql"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "wrangler": "^3.78.0"
  }
}
