# Server
PORT=3000
NODE_ENV=development

# CORS - the URL where your Mini App frontend is hosted
FRONTEND_URL=http://localhost:5173

# Telegram
# Get this from @BotFather after creating your bot
TELEGRAM_BOT_TOKEN=123456:ABC-YOUR-BOT-TOKEN
# Set to "false" only for local browser testing without Telegram. NEVER false in production.
AUTH_REQUIRE_SIGNATURE=true

# Football data API (https://www.football-data.org - free tier available)
# If left empty, the backend falls back to bundled mock fixtures so the app still runs.
FOOTBALL_API_KEY=
FOOTBALL_API_BASE=https://api.football-data.org/v4
# Competition code for the World Cup on football-data.org is "WC"
FOOTBALL_COMPETITION=WC

# How often (ms) to poll the football API for finished matches to settle predictions
SETTLE_INTERVAL_MS=120000

# Database file location (relative to Backend/). Points at the project-root Database/ folder.
DATABASE_PATH=../Database/worldcup.db
